        "# ── FEDERATED LEARNING UTILITIES ─────────────────────────────\n",
        "\n",
        "def get_weights(model):\n",
        "    return model.get_weights()\n",
        "\n",
        "def set_weights(model, weights):\n",
        "    model.set_weights(weights)\n",
        "\n",
        "def fedavg(all_weights, client_sizes):\n",
        "    \"\"\"Weighted FedAvg — larger clients contribute more.\"\"\"\n",
        "    total = sum(client_sizes)\n",
        "    averaged = []\n",
        "    for layer_idx in range(len(all_weights[0])):\n",
        "        layer_avg = np.zeros_like(all_weights[0][layer_idx], dtype=np.float64)\n",
        "        for cid, w in enumerate(all_weights):\n",
        "            layer_avg += w[layer_idx] * (client_sizes[cid] / total)\n",
        "        averaged.append(layer_avg.astype(np.float32))\n",
        "    return averaged\n",
        "\n",
        "def to_cnn_shape(X):\n",
        "    \"\"\"Reshape flat features → (samples, features, 1) for CNN.\"\"\"\n",
        "    return X.reshape(X.shape[0], X.shape[1], 1)\n",
        "\n",
        "def evaluate_cnn(model, X_test, y_test):\n",
        "    y_pred = np.argmax(model.predict(to_cnn_shape(X_test),\n",
        "                                     verbose=0), axis=1)\n",
        "    acc  = accuracy_score(y_test, y_pred)\n",
        "    f1   = f1_score(y_test, y_pred, average='weighted', zero_division=0)\n",
        "    prec = precision_score(y_test, y_pred, average='weighted', zero_division=0)\n",
        "    rec  = recall_score(y_test, y_pred, average='weighted', zero_division=0)\n",
        "    return acc, f1, prec, rec, y_pred\n",
        "\n",
        "print(\"Utilities defined ✓\")"
