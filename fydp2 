        "# ── LIGHTWEIGHT 1D-CNN CLASSIFIER ────────────────────────────\n",
        "# Very small CNN — designed for resource-constrained IoMT devices\n",
        "# Uses depthwise separable idea: few filters, small kernels\n",
        "\n",
        "def build_lightweight_cnn(input_dim, num_classes):\n",
        "    inputs = keras.Input(shape=(input_dim, 1), name='cnn_input')\n",
        "\n",
        "    # Block 1 — small filter count on purpose (lightweight)\n",
        "    x = layers.Conv1D(filters=32, kernel_size=3, activation='relu',\n",
        "                      padding='same', name='conv1')(inputs)\n",
        "    x = layers.BatchNormalization()(x)\n",
        "    x = layers.MaxPooling1D(pool_size=2, name='pool1')(x)\n",
        "    x = layers.Dropout(0.1)(x)\n",
        "\n",
        "    # Block 2\n",
        "    x = layers.Conv1D(filters=64, kernel_size=3, activation='relu',\n",
        "                      padding='same', name='conv2')(x)\n",
        "    x = layers.BatchNormalization()(x)\n",
        "    x = layers.GlobalAveragePooling1D(name='gap')(x)  # GAP instead of Flatten\n",
        "                                                       # — much fewer params\n",
        "    x = layers.Dropout(0.1)(x)\n",
        "\n",
        "    # Tiny dense head\n",
        "    x = layers.Dense(32, activation='relu', name='dense1')(x)\n",
        "    x = layers.Dropout(0.1)(x)\n",
        "    outputs = layers.Dense(num_classes, activation='softmax',\n",
        "                           name='output')(x)\n",
        "\n",
        "    model = Model(inputs, outputs, name='Lightweight_CNN_IDS')\n",
        "    model.compile(\n",
        "        optimizer=keras.optimizers.Adam(learning_rate=0.001),\n",
        "        loss='sparse_categorical_crossentropy',\n",
        "        metrics=['accuracy']\n",
        "    )\n",
        "    return model\n",
        "\n",
        "cnn_model = build_lightweight_cnn(NUM_FEATURES, NUM_CLASSES)\n",
        "cnn_model.summary()\n",
        "\n",
        "total_params = cnn_model.count_params()\n",
        "print(f\"\\nTotal parameters : {total_params:,}\")\n",
        "print(f\"Model size (KB)  : {total_params * 4 / 1024:.1f} KB\")"
