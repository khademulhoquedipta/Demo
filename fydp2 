        "# ── AUTOENCODER EVALUATION ────────────────────────────────────\n",
        "# AE does not classify directly — it detects anomalies via\n",
        "# reconstruction error. High error = attack, low error = normal.\n",
        "\n",
        "X_all = np.vstack([client_data[i]['X_test'] for i in range(NUM_CLIENTS)])\n",
        "y_all = np.concatenate([client_data[i]['y_test'] for i in range(NUM_CLIENTS)])\n",
        "\n",
        "# Get reconstruction error for every sample\n",
        "X_reconstructed = global_ae.predict(X_all, verbose=0)\n",
        "recon_errors     = np.mean(np.square(X_all - X_reconstructed), axis=1)\n",
        "\n",
        "# Find normal class index\n",
        "normal_idx = le.transform(['Normal'])[0] if 'Normal' in le.classes_ else 0\n",
        "\n",
        "# Binary ground truth: 0=normal, 1=attack\n",
        "y_binary_true = (y_all != normal_idx).astype(int)\n",
        "\n",
        "# Try multiple thresholds — pick the one with best F1\n",
        "from sklearn.metrics import f1_score as f1_fn\n",
        "\n",
        "thresholds  = np.percentile(recon_errors, np.arange(50, 99, 1))\n",
        "best_thresh = thresholds[0]\n",
        "best_f1     = 0\n",
        "\n",
        "for t in thresholds:\n",
        "    y_pred_binary = (recon_errors > t).astype(int)\n",
        "    score = f1_fn(y_binary_true, y_pred_binary, zero_division=0)\n",
        "    if score > best_f1:\n",
        "        best_f1     = score\n",
        "        best_thresh = t\n",
        "\n",
        "# Final AE predictions using best threshold\n",
        "y_pred_ae_binary = (recon_errors > best_thresh).astype(int)\n",
        "ae_acc  = accuracy_score(y_binary_true, y_pred_ae_binary)\n",
        "ae_f1   = f1_score(y_binary_true, y_pred_ae_binary,\n",
        "                   average='weighted', zero_division=0)\n",
        "ae_prec = precision_score(y_binary_true, y_pred_ae_binary,\n",
        "                          average='weighted', zero_division=0)\n",
        "ae_rec  = recall_score(y_binary_true, y_pred_ae_binary,\n",
        "                       average='weighted', zero_division=0)\n",
        "\n",
        "print(f\"Autoencoder (binary: normal vs attack)\")\n",
        "print(f\"  Best threshold : {best_thresh:.6f}\")\n",
        "print(f\"  Accuracy       : {ae_acc:.4f}\")\n",
