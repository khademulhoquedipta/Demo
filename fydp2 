        "import pandas as pd\n",
        "import numpy as np\n",
        "import os\n",
        "\n",
        "# ── Label mapping ──────────────────────────────────────────────\n",
        "# Your filenames contain the attack type — extract it automatically\n",
        "def get_label_from_filename(filename):\n",
        "    name = filename.lower()\n",
        "    if 'benign' in name or 'normal' in name or 'legitimate' in name:\n",
        "        return 'Normal'\n",
        "    elif 'icmp' in name:\n",
        "        return 'DoS-ICMP'\n",
        "    elif 'syn' in name:\n",
        "        return 'DoS-SYN'\n",
        "    elif 'udp2' in name or 'ddos-udp' in name:\n",
        "        return 'DDoS-UDP'\n",
        "    elif 'ddos' in name:\n",
        "        return 'DDoS'\n",
        "    elif 'dos' in name:\n",
        "        return 'DoS'\n",
        "    elif 'mqtt' in name:\n",
        "        return 'MQTT'\n",
        "    elif 'recon' in name or 'scan' in name:\n",
        "        return 'Recon'\n",
        "    elif 'mirai' in name:\n",
        "        return 'Mirai'\n",
        "    elif 'spoofing' in name or 'arp' in name:\n",
        "        return 'Spoofing'\n",
        "    else:\n",
        "        return 'Unknown'\n",
        "\n",
        "# ── Load and combine all uploaded files ───────────────────────\n",
        "dfs = []\n",
        "for filename in uploaded.keys():\n",
        "    label = get_label_from_filename(filename)\n",
        "    df_tmp = pd.read_csv(filename)\n",
        "    df_tmp['label'] = label\n",
        "    dfs.append(df_tmp)\n",
        "    print(f\"  Loaded: {filename:50s} → label='{label}', rows={len(df_tmp)}\")\n",
        "\n",
        "df = pd.concat(dfs, ignore_index=True)\n",
        "print(f\"\\nCombined dataset: {df.shape}\")\n",
        "print(f\"\\nLabel distribution:\\n{df['label'].value_counts()}\")"
