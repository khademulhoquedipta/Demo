        "# ── LIGHTWEIGHT AUTOENCODER ───────────────────────────────────\n",
        "# Tiny encoder: compresses features into small bottleneck\n",
        "# Suitable for low-power IoMT devices\n",
        "\n",
        "def build_autoencoder(input_dim):\n",
        "    inputs = keras.Input(shape=(input_dim,), name='input')\n",
        "\n",
        "    # Encoder — compress down to 16 dimensions only\n",
        "    x = layers.Dense(64, activation='relu', name='enc1')(inputs)\n",
        "    x = layers.BatchNormalization()(x)\n",
        "    x = layers.Dropout(0.1)(x)\n",
        "    x = layers.Dense(32, activation='relu', name='enc2')(x)\n",
        "    x = layers.BatchNormalization()(x)\n",
        "    encoded = layers.Dense(16, activation='relu',\n",
        "                           name='bottleneck')(x)  # very small bottleneck\n",
        "\n",
        "    # Decoder — reconstruct back to original size\n",
        "    x = layers.Dense(32, activation='relu', name='dec1')(encoded)\n",
        "    x = layers.BatchNormalization()(x)\n",
        "    x = layers.Dropout(0.1)(x)\n",
        "    x = layers.Dense(64, activation='relu', name='dec2')(x)\n",
        "    x = layers.BatchNormalization()(x)\n",
        "    decoded = layers.Dense(input_dim, activation='sigmoid',\n",
        "                           name='output')(x)\n",
        "\n",
        "    autoencoder = Model(inputs, decoded, name='Lightweight_AE')\n",
        "    encoder     = Model(inputs, encoded, name='Lightweight_Encoder')\n",
        "\n",
        "    autoencoder.compile(\n",
        "        optimizer=keras.optimizers.Adam(learning_rate=0.001),\n",
        "        loss='mse'\n",
        "    )\n",
        "    return autoencoder, encoder\n",
        "\n",
        "ae, enc = build_autoencoder(NUM_FEATURES)\n",
        "ae.summary()\n",
